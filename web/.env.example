# ─────────────────────────────────────────────────────────────────
#  Hotel zur Post – Frontend Environment
# ─────────────────────────────────────────────────────────────────
# Diese Datei in `.env.local` kopieren und Werte einsetzen.
# `.env.local` ist via .gitignore aus der Versionskontrolle ausgeschlossen.

# Sanity-Anbindung (optional in der Discovery/Mock-Phase)
# Sobald Phase 2 Studio deployed ist, hier Werte eintragen –
# bis dahin liefert /src/lib/data.ts die Mock-Daten aus dem Seed.
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"

# Token nur für ISR-Webhook-Validierung (server-only)
SANITY_REVALIDATE_SECRET=""

# Site-Basis-URL (für SEO, Sitemap, OG-Images)
NEXT_PUBLIC_SITE_URL="https://www.hotel-kiefersfelden.de"

# Open-Meteo (kostenlos, keine API-Key) – Berg-Wetter für /wetter & Widget
NEXT_PUBLIC_WEATHER_PROVIDER="open-meteo"
