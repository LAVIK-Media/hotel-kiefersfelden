# Sanity-Projekt — Konfigurations-Vorlage
# Diese Datei in `.env` kopieren und Werte einsetzen.
# `.env` ist via .gitignore aus Versionskontrolle ausgeschlossen.

# Projekt-ID (sichtbar im Sanity-Dashboard auf sanity.io/manage)
SANITY_STUDIO_PROJECT_ID="REPLACE_WITH_PROJECT_ID"

# Dataset (üblicherweise "production")
SANITY_STUDIO_DATASET="production"

# Studio-Hostname für sanity.io (optional, für gehostetes Studio)
# Ergebnis: https://<hostname>.sanity.studio
SANITY_STUDIO_HOSTNAME="hotel-zur-post"

# Token mit Schreibrechten — NUR für lokales Seed-Script.
# Erstellen: sanity.io/manage → Project → API → Tokens → "Editor"
# NIEMALS ins Repo committen.
SANITY_API_WRITE_TOKEN=""
