# Root ignores (monorepo: web + sanity)

# dependencies / build
**/node_modules/
**/.next/
**/out/
**/dist/
**/.sanity/

# env (never commit real secrets)
**/.env
**/.env.*
!**/.env.example

# logs
**/*.log

# OS / editor
.DS_Store
Thumbs.db

# Cursor / local agent config
.claude/

# misc
**/*.tsbuildinfo
